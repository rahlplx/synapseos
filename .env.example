# ─── SynapseOS Environment ───────────────────────────────────────────────────
# Copy to .env and fill values. NEVER commit .env to git.

# ── LLM Routing (Groq primary — free tier, generous limits)
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Database
POSTGRES_PASSWORD=change_this_strong_password
DATABASE_URL=postgresql+asyncpg://synapse:change_this_strong_password@postgres:5432/synapseos

# ── MinIO Object Storage
MINIO_USER=synapseos
MINIO_PASSWORD=change_this_strong_password
MINIO_ENDPOINT=minio:9000

# ── BYOK Tenant Key Encryption (AES-256 Fernet)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate_fernet_key_here

# ── Langfuse Self-Hosted Observability
LANGFUSE_PUBLIC_KEY=pk-lf-replace_me
LANGFUSE_SECRET_KEY=sk-lf-replace_me
LANGFUSE_NEXTAUTH_SECRET=generate_32_random_chars_here
LANGFUSE_SALT=generate_32_random_chars_here
LANGFUSE_HOST=http://langfuse:3100

# ── Internal Service Keys
MCP_SERVICE_KEY=sk-syn-mcp-replace_me

# ── Runtime (ARM CPU optimization)
OMP_NUM_THREADS=4
DOCLING_CPU_ONLY=1
