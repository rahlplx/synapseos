# ─── SynapseOS Environment ───────────────────────────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env

# ── z.ai (primary LLM — free flash models + flagship)
ZAI_API_KEY=your_zai_api_key_here

# ── LLM fallback chain
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Database
POSTGRES_PASSWORD=change_this_strong_password
DATABASE_URL=postgresql+asyncpg://synapse:change_this_strong_password@postgres:5432/synapseos

# ── MinIO
MINIO_USER=synapseos
MINIO_PASSWORD=change_this_strong_password

# ── Encryption (for BYOK tenant keys at rest)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate_fernet_key_here

# ── Langfuse (self-hosted observability)
LANGFUSE_PUBLIC_KEY=pk-lf-replace_me
LANGFUSE_SECRET_KEY=sk-lf-replace_me
LANGFUSE_NEXTAUTH_SECRET=generate_random_32_chars
LANGFUSE_SALT=generate_random_32_chars

# ── Service keys
MCP_SERVICE_KEY=sk-syn-mcp-replace_me

# ── Runtime
OMP_NUM_THREADS=4
